#!/usr/bin/env bash

__lamp__help() {
  cat <<EOF
Usage: lamp [command] [options]

Commands:
  create <name>             Create a virtual host
    --database [name]        Create a database (default: <name>)
    --php <version>          Specify the PHP version (default: __PHP_VERSION__)

  delete <name>             Delete the virtual host
                            To avoid data loss, the directory is not deleted
    --database [name]        Delete the database (default: <name>)

  enable <name>             Enable virtual host
  disable <name>            Disable virtual host

  list                      List the generated virtual hosts
    --filter <status>        Filter by status: enabled, disabled

  restart [services]        Restart all services or the specified service
                            Use 'php' or 'php-fpm' to restart all PHP-FPM

  help                      Show this help message

Note:
  - The <name> argument becomes the <name>.__TLD__ domain and vhost (folder)
EOF
  exit 0
}

__lamp__list() {
  local filter="none"
  if [[ -n "$1" ]]; then
    if [[ "$1" != "--filter" ]]; then
      echo "Unknown option."
      exit 2
    fi
    if ! [[ "${2:-}" =~ ^(enabled|disabled)$ ]]; then
      echo "Invalid filter value."
      exit 2
    fi
    filter="$2"
  fi

  find /etc/apache2/sites-available -maxdepth 1 -name "*.conf" 2>/dev/null |
    awk -F'/' -v filter="$filter" '
    BEGIN { nlen = 6; count = 0 }
    {
      conf = $NF
      status = "disabled"
      if (system("test -f /etc/apache2/sites-enabled/" conf) == 0) {
        status = "enabled"
      }
      if (filter == "none" || filter == status) {
        count++
        vhost = substr(conf, 1, length(conf) - 5)
        len = length(vhost)
        if (len > nlen) {
          nlen = len
        }
        vhosts[count] = vhost
        statuses[count] = status
      }
    }
    END {
    if (count == 0) {
      print "No domain found."
      exit 1
    }
    nlen += 2
    if (filter == "none") {
      printf "%-*s %s\n", nlen, "DOMAIN", "STATUS"
      for (i=1; i<=count; i++) {
        printf "%-*s %s\n", nlen, vhosts[i], statuses[i]
      }
    } else {
      for (i=1; i<=count; i++) {
        print vhosts[i]
      }
    }
  }'
  exit 0
}

__lamp__restart() {
  local name services=()
  local exit_code=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
    php | php-fpm)
      for name in /etc/php/*; do
        services+=("php${name##*/}-fpm")
      done
      ;;
    *) services+=("$1") ;;
    esac
    shift
  done

  for name in "${services[@]}"; do
    echo "Restarting the $name service."
    if ! systemctl restart "$name" >/dev/null 2>&1; then
      exit_code=$?
      echo "Failed to restart the $name service. Check the logs."
    fi
  done
  return $exit_code
}

__lamp__restart_server() {
  if ! __lamp__restart "php" "apache2" >/dev/null 2>&1; then
    echo "Failed to restart the server services, check the logs."
    return 1
  fi
  return 0
}

__lamp__enable() {
  local domain="$1"
  if [[ ! -f "/etc/apache2/sites-available/$domain.conf" ]]; then
    echo "The \"$domain\" virtual host does not exist."
    return 1
  fi
  if [[ -f "/etc/apache2/sites-enabled/$domain.conf" ]]; then
    echo "The \"$domain\" virtual host is already enabled."
    return 0
  fi
  ln -s "/etc/apache2/sites-available/$domain.conf" "/etc/apache2/sites-enabled/$domain.conf"
  echo "The \"$domain\" virtual host is enabled."
  __lamp__restart_server
  return $?
}

__lamp__disable() {
  local domain="$1"
  if [[ ! -f "/etc/apache2/sites-available/$domain.conf" ]]; then
    echo "The \"$domain\" virtual host does not exist."
    return 1
  fi
  if [[ ! -f "/etc/apache2/sites-enabled/$domain.conf" ]]; then
    echo "The \"$domain\" virtual host is not enabled."
    return 0
  fi
  rm -f "/etc/apache2/sites-enabled/$domain.conf"
  echo "The \"$domain\" virtual host is disabled."
  __lamp__restart_server
  return $?
}

__lamp__create() {
  local vhost="$1" domain="$2" database="$3" php_version="$4"
  local docroot="__VIRTUALHOSTS_DIRECTORY__"

  if [[ -n "$php_version" ]]; then
    if ! [[ "$php_version" =~ ^[0-9]\.[0-9]$ ]]; then
      echo "Invalid PHP format version, changing to __PHP_VERSION__."
      php_version="__PHP_VERSION__"
    fi
    if ! [[ -f "/etc/php/$php_version/fpm/pool.d/user.conf" ]]; then
      echo "Missing PHP-FPM pool for $php_version version, skipping."
      return 1
    fi
  fi

  if [[ -f "/etc/apache2/sites-enabled/$vhost.conf" ]]; then
    rm -f "/etc/apache2/sites-enabled/$vhost.conf"
    echo "Updating the \"$vhost\" virtual host."
  else
    echo "Creating the \"$vhost\" virtual host."
  fi

  docroot="${docroot%/}/$vhost"

  if [[ ! -d "$docroot" ]]; then
    echo "Creating the directory (DocumentRoot)."
    if ! mkdir "$docroot"; then
      echo "Failed to create the directory (DocumentRoot), skipping."
      return 1
    fi
  fi

  mkcert create "$domain"
  if [[ ! -f "/opt/mkcert/certificates/$domain.pem" ]]; then
    echo "Missing $domain certificate, skipping."
    return 1
  fi

  if [[ -n "$database" ]]; then
    echo "Create the \"$database\" database if not exists."
    mariadb -e "CREATE DATABASE IF NOT EXISTS \`$database\`;" || :
  fi

  if [[ "$vhost" != "$domain" ]]; then
    echo "$vhost is a subdomain of $domain, skipping ServerAlias."
  fi

  {
    echo "<VirtualHost *:443>"
    echo "  ServerName $vhost"
    if [[ "$vhost" == "$domain" ]]; then
      echo "  ServerAlias *.$vhost"
    fi
    echo "  ServerAdmin webmaster@$domain"
    echo "  DocumentRoot $docroot"
    echo "  SSLCertificateFile /opt/mkcert/certificates/$domain.pem"
    if [[ -n "$php_version" && "$php_version" != "__PHP_VERSION__" ]]; then
      echo "  <Directory $docroot/>"
      echo "    <FilesMatch \".+\.ph(ar|p|tml)$\">"
      echo "      SetHandler \"proxy:unix:/run/php/$php_version-fpm-user.sock|fcgi://localhost\""
      echo "    </FilesMatch>"
      echo "  </Directory>"
    fi
    echo "</VirtualHost>"
  } >"/etc/apache2/sites-available/$vhost.conf"

  if [[ ! -f "/etc/apache2/sites-available/$vhost.conf" ]]; then
    echo "Failed to create the virtual host configuration."
    return 1
  fi

  __lamp__enable "$vhost"
  return $?
}

__lamp__delete() {
  local vhost="$1" domain="$2" database="$3"

  if [[ ! -f "/etc/apache2/sites-available/$vhost.conf" ]]; then
    echo "The virtual host does not exist, skipping."
    return 1
  fi

  rm -f "/etc/apache2/sites-enabled/$vhost.conf"
  rm -f "/etc/apache2/sites-available/$vhost.conf"
  if [[ -f "/etc/apache2/sites-available/$domain.conf" ]]; then
    echo "Skipping the certificate deletion because the $vhost is a subdomain of $domain."
  else
    mkcert delete "$domain"
  fi

  if [[ -n "$database" ]]; then
    echo "Deleting the \"$database\" database if exists."
    mariadb -e "DROP DATABASE IF EXISTS \`$database\`;" 2>&1 && echo "Executed without errors."
  else
    echo "The database name was not defined, skipping the database deletion."
  fi

  echo "The virtual host configuration files were deleted."
  __lamp__restart_server
  return $?
}

__lamp__validate_domain() {
  [[ $# -gt 0 && "$1" =~ ^[[:alnum:]]([[:alnum:]\-]{0,62}[[:alnum:]]\.)?[[:alnum:]\-]{0,62}[[:alnum:]]\.[[:alpha:]]{2,}$ ]]
}

__lamp__add_domain_tld() {
  local domain="$1"
  if [[ -n "$domain" ]] && ! [[ "$domain" =~ \.__TLD__$ ]]; then
    domain+=".__TLD__"
  fi
  echo "$domain"
}

__lamp() {
  local cmd

  case "${1:-help}" in
  create | delete | enable | disable | restart)
    cmd="$1"
    shift
    ;;
  list)
    shift
    __lamp__list "$@"
    ;;
  help) __lamp__help ;;
  esac

  if [[ -z "$cmd" ]]; then
    echo "Unknown command. Use 'lamp help' for usage."
    return 2
  fi

  if [[ "$(id -u)" -ne "0" ]]; then
    if command -v sudo >/dev/null 2>&1; then
      echo "Not running as root, auto-executing with sudo"
      exec sudo lamp "$cmd" "$@"
    fi
    echo "The sudo command not found. Please run this script as root."
    return 1
  fi

  if [[ "$cmd" == "restart" ]]; then

    if [[ $# -eq 0 ]]; then
      set -- "php" "apache2" "mariadb" "mailpit" "coredns"
    fi
    __lamp__restart "$@"
    return $?
  fi

  if [[ $# -eq 0 ]]; then
    echo "No domain defined for the $cmd command."
    return 2
  fi

  if [[ "$1" =~ ^- ]]; then
    echo "Arguments are positional, the domain must be the first argument."
    return 2
  fi

  local vhost
  vhost="$(__lamp__add_domain_tld "$1")"
  if ! __lamp__validate_domain "$vhost"; then
    echo "Invalid format for the domain: $vhost"
    return 2
  fi

  case "$cmd" in
  enable)
    __lamp__enable "$vhost"
    return $?
    ;;
  disable)
    __lamp__disable "$vhost"
    return $?
    ;;
  *)
    shift # Remove the first argument (vhost).
    ;;
  esac

  local domain
  local database
  local php_version="__PHP_VERSION__"

  domain="$(awk -F'.' 'END{print $(NF-1)"."$NF}' <<<"$vhost")"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --database)
      if [[ -n "$2" ]] && ! [[ "$2" =~ ^- ]]; then
        database="$2"
        shift
      elif [[ "$vhost" == "$domain" ]]; then
        database="$(awk -F'.' 'END{print $(NF-1)}' <<<"$vhost")"
      else
        echo "Subdomain detected. Use '--database <name>' to specify a database."
        return 2
      fi
      ;;
    --php)
      if [[ -n "$2" ]] && ! [[ "$2" =~ ^- ]]; then
        php_version="$2"
        shift
      fi
      ;;
    *)
      echo "Unknown '$1' option. Use 'lamp help' for usage."
      return 2
      ;;
    esac
    shift
  done

  case "$cmd" in
  create)
    __lamp__create "$vhost" "$domain" "$database" "$php_version"
    return $?
    ;;
  delete)
    __lamp__delete "$vhost" "$domain" "$database"
    return $?
    ;;
  esac
  return 0
}

__lamp "$@"
exit $?
